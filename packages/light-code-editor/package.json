{
  "name": "@editora/light-code-editor",
  "version": "1.0.8",
  "description": "Lightweight code editor for React and web apps with syntax highlighting, search/replace, extensions, and enterprise SaaS integration patterns.",
  "authors": [
    "Ajay Kumar <ajaykr089@gmail.com>"
  ],
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "default": "./dist/index.es.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.css",
    "dist/**/*.d.ts",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:types",
    "build:js": "vite build",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly --noEmit false --outDir dist",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "react ui library",
    "react component library",
    "saas ui components",
    "enterprise react components",
    "modern design system",
    "rich text editor react",
    "code-editor",
    "lightweight-editor",
    "syntax-highlighting",
    "javascript-editor",
    "typescript-editor",
    "web-editor",
    "code-playground",
    "line-numbers",
    "code-folding",
    "plugin-friendly"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ajaykr089/Editora.git",
    "directory": "packages/light-code-editor"
  },
  "homepage": "https://editora-ecosystem.netlify.app/docs/packages/light-code-editor",
  "bugs": {
    "url": "https://github.com/ajaykr089/Editora/issues"
  },
  "style": "dist/light-code-editor.css",
  "publishConfig": {
    "access": "public"
  },
  "author": "Ajay Kumar <ajaykr089@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.5.14"
  },
  "gitHead": "80e0808ae4909de63b8e0f1dd915b06b33a8ed44"
}
