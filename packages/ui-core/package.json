{
  "name": "@editora/ui-core",
  "version": "0.1.8",
  "description": "Framework-agnostic Web Components and primitives for the Editora UI ecosystem",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.esm.js"
    },
    "./sortable": {
      "types": "./dist/sortable.d.ts",
      "import": "./dist/sortable.esm.js",
      "require": "./dist/sortable.cjs.js",
      "default": "./dist/sortable.esm.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.esm.js",
      "require": "./dist/runtime.cjs.js",
      "default": "./dist/runtime.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:tsc": "npm --prefix ../icons run build:tsc && tsc -p . --emitDeclarationOnly --noEmit false --outDir dist",
    "build": "npm --prefix ../icons run build:tsc && vite build && npm run build:tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "dev": "vite build --watch",
    "clean": "rimraf dist",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "jsdom": "^22.1.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.5.14",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@editora/icons": "^0.1.5"
  },
  "keywords": [
    "editora",
    "editora ui ecosystem",
    "ui-core",
    "ui-sortable",
    "design-system",
    "web-components",
    "typescript",
    "reactivity",
    "admin-ui",
    "accessible-ui"
  ],
  "author": "Ajay Kumar <ajaykr089@gmail.com>",
  "license": "MIT",
  "sideEffects": true,
  "gitHead": "7883627e823aa99dd5ecb66a5201116df972f88b"
}
