{
  "name": "@editora/citations",
  "version": "1.0.1",
  "description": "Native citation and bibliography plugin for Editora with APA/MLA/Chicago support",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build"
  },
  "keywords": [
    "editora",
    "citations",
    "bibliography",
    "apa",
    "mla",
    "chicago"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ajaykr089/Editora.git",
    "directory": "packages/plugins/citations"
  },
  "license": "MIT",
  "dependencies": {
    "@editora/core": "^1.0.14"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.esm.js"
    }
  },
  "homepage": "https://editora-ecosystem.netlify.app/",
  "bugs": {
    "url": "https://github.com/ajaykr089/Editora/issues"
  }
