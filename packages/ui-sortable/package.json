{
  "name": "@editora/ui-sortable",
  "version": "0.1.1",
  "description": "Standalone install for the Editora sortable web component, with reordering, transfer, hierarchy, cloning, and keyboard-accessible drag and drop.",
  "homepage": "https://editora-ecosystem.netlify.app/docs/ui-react/interactive/sortable",
  "bugs": {
    "url": "https://github.com/ajaykr089/Editora/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ajaykr089/Editora.git",
    "directory": "packages/ui-sortable"
  },
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.esm.js"
    },
    "./react": {
      "types": "./react.d.ts",
      "import": "./dist/react.esm.js",
      "require": "./dist/react.cjs.js",
      "default": "./dist/react.esm.js"
    }
  },
  "files": [
    "dist",
    "index.d.ts",
    "react.d.ts"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@editora/ui-core": "^0.1.9"
  },
  "peerDependencies": {
    "react": ">=16.8 <21",
    "react-dom": ">=16.8 <21"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "jsdom": "^22.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.5.14",
    "vitest": "^1.6.1"
  },
  "keywords": [
    "editora",
    "sortable",
    "drag-and-drop",
    "web-components",
    "kanban",
    "tree",
    "accessible-ui"
  ],
  "author": "Ajay Kumar <ajaykr089@gmail.com>",
  "license": "MIT",
  "sideEffects": true,
  "publishConfig": {
    "access": "public"
  }
}
