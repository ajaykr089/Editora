{
  "name": "@editora/ui-react",
  "version": "0.1.6",
  "description": "Enterprise React component library with SaaS UI components, modern design system patterns, and wrappers for Editora UI Core.",
  "homepage": "https://editora-ecosystem.netlify.app/docs/ui-react",
  "bugs": {
    "url": "https://github.com/ajaykr089/Editora/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ajaykr089/Editora.git",
    "directory": "packages/ui-react"
  },
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.esm.js"
    },
    "./Breadcrumb": {
      "types": "./dist/Breadcrumb.d.ts",
      "import": "./dist/Breadcrumb.esm.js",
      "require": "./dist/Breadcrumb.cjs.js",
      "default": "./dist/Breadcrumb.esm.js"
    },
    "./Collapsible": {
      "types": "./dist/Collapsible.d.ts",
      "import": "./dist/Collapsible.esm.js",
      "require": "./dist/Collapsible.cjs.js",
      "default": "./dist/Collapsible.esm.js"
    },
    "./Combobox": {
      "types": "./dist/Combobox.d.ts",
      "import": "./dist/Combobox.esm.js",
      "require": "./dist/Combobox.cjs.js",
      "default": "./dist/Combobox.esm.js"
    },
    "./Command": {
      "types": "./dist/Command.d.ts",
      "import": "./dist/Command.esm.js",
      "require": "./dist/Command.cjs.js",
      "default": "./dist/Command.esm.js"
    },
    "./CommandPalette": {
      "types": "./dist/CommandPalette.d.ts",
      "import": "./dist/CommandPalette.esm.js",
      "require": "./dist/CommandPalette.cjs.js",
      "default": "./dist/CommandPalette.esm.js"
    },
    "./Drawer": {
      "types": "./dist/Drawer.d.ts",
      "import": "./dist/Drawer.esm.js",
      "require": "./dist/Drawer.cjs.js",
      "default": "./dist/Drawer.esm.js"
    },
    "./FloatingToolbar": {
      "types": "./dist/FloatingToolbar.d.ts",
      "import": "./dist/FloatingToolbar.esm.js",
      "require": "./dist/FloatingToolbar.cjs.js",
      "default": "./dist/FloatingToolbar.esm.js"
    },
    "./Form": {
      "types": "./dist/Form.d.ts",
      "import": "./dist/Form.esm.js",
      "require": "./dist/Form.cjs.js",
      "default": "./dist/Form.esm.js"
    },
    "./HoverCard": {
      "types": "./dist/HoverCard.d.ts",
      "import": "./dist/HoverCard.esm.js",
      "require": "./dist/HoverCard.cjs.js",
      "default": "./dist/HoverCard.esm.js"
    },
    "./Input": {
      "types": "./dist/Input.d.ts",
      "import": "./dist/Input.esm.js",
      "require": "./dist/Input.cjs.js",
      "default": "./dist/Input.esm.js"
    },
    "./Layout": {
      "types": "./dist/Layout.d.ts",
      "import": "./dist/Layout.esm.js",
      "require": "./dist/Layout.cjs.js",
      "default": "./dist/Layout.esm.js"
    },
    "./Menu": {
      "types": "./dist/Menu.d.ts",
      "import": "./dist/Menu.esm.js",
      "require": "./dist/Menu.cjs.js",
      "default": "./dist/Menu.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:tsc": "npm --prefix ../ui-core run build:tsc && tsc -p . --emitDeclarationOnly --noEmit false --outDir dist",
    "build": "npm --prefix ../ui-core run build:tsc && vite build && npm run build:tsc",
    "dev": "vite build --watch",
    "dev:examples": "vite --config examples/vite.config.ts",
    "build:examples": "vite build --config examples/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "jsdom": "^22.1.0",
    "typescript": "^5.0.0",
    "vite": "^4.5.14",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "react": ">=16.8 <21",
    "react-dom": ">=16.8 <21"
  },
  "dependencies": {
    "@editora/toast": "^2.0.5",
    "@editora/ui-core": "^0.1.5"
  },
  "keywords": [
    "editora",
    "react ui library",
    "react component library",
    "saas ui components",
    "enterprise react components",
    "modern design system",
    "rich text editor react",
    "editora ui ecosystem",
    "ui-react",
    "react",
    "web-components",
    "design-system",
    "typescript",
    "admin-ui",
    "component-library"
  ],
  "author": "Ajay Kumar <ajaykr089@gmail.com>",
  "license": "MIT",
  "sideEffects": true,
  "gitHead": "7883627e823aa99dd5ecb66a5201116df972f88b"
}
